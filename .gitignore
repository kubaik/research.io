# ── NEVER COMMIT ─────────────────────────────────────────────────
.env
.env.*
*.pyc
__pycache__/
.secrets_cache.json

# Build output — docs/ for local dev, _site/ for CI
# Both contain chat.js with a live API token baked in at build time.
# NEVER commit either. GitHub push protection will block it.
#
# How it works:
#   Local dev → python chatbot_system.py build   → writes to docs/
#   CI/Actions → BUILD_OUTPUT_DIR=_site python … → writes to _site/
#
# _site/ is used in CI because upload-pages-artifact@v3 runs `git add`
# internally — which exits 1 if the path is gitignored at that point.
_site/
